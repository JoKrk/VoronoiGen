@page "/"
@using VoronoiGen.Models
@using VoronoiGen.Services
@using System.Numerics
@using System.Linq
@using System.Threading

<PageTitle>Voronoi DXF Tool</PageTitle>

<header>
    <h1>Voronoi DXF — Holes + Offsets</h1>
    <p class="text-muted">Generate Voronoi diagrams from DXF files with advanced control over cell distribution, smoothing, and offset parameters.</p>
</header>

<!-- File Upload Section -->
<section class="upload-section">
    <InputFile OnChange="OnFileSelected" accept=".dxf" />

    @if (_import?.Outer is null)
    {
        <p class="mt-3">📁 Upload a DXF file with a closed outline to begin.</p>
    }
    else
    {
        <p class="mt-3" style="color: var(--color-success); font-weight: 500;">
            ✓ Boundary loaded — Area: <code>@_import!.Outer.Area():F0</code> units² | Holes: <code>@_import!.Holes.Count</code>
        </p>
    }
</section>

<!-- Parameter Controls -->
<section class="controls">
    <!-- Boundary Controls -->
    <label title="Enable or disable hole detection in the imported geometry. When enabled, holes will be respected as void regions where no Voronoi cells will be generated.">
        Use Holes
        <input type="checkbox" @bind="UseHoles" disabled="@IsGenerating" />
    </label>

    <label title="Inset margin from the outer boundary. Positive values push Voronoi cells away from the boundary edge, creating a margin. Applied as a negative offset to shrink the working boundary.">
        Outer Offset
        <input type="number" step="0.5" min="0" @bind="OuterOffset" disabled="@IsGenerating" />
    </label>

    <label title="Expands hole boundaries outward. Positive values grow hole masks, reducing the available area for Voronoi cell generation around obstacles.">
        Inner Offset
        <input type="number" step="0.5" min="0" @bind="InnerOffset" disabled="@IsGenerating" />
    </label>

    <!-- Seed Generation Controls -->
    <label title="Minimum spacing between seed points using Poisson disk sampling. Larger values create more uniform, evenly-spaced distributions. Measured in the same units as your DXF geometry.">
        Min Spacing (Poisson Radius)
        <input type="number" step="0.5" min="1" @bind="PoissonRadius" disabled="@IsGenerating" />
    </label>

    <label title="Target number of seed points when using random generation (fallback if Poisson sampling fails). Higher values create more, smaller Voronoi cells.">
        Seed Count
        <input type="number" min="1" max="5000" @bind="SeedCount" disabled="@IsGenerating" />
    </label>

    <label title="Random number generator seed for reproducible results. Using the same seed with identical parameters will produce the exact same pattern.">
        RNG Seed
        <input type="number" @bind="RngSeed" disabled="@IsGenerating" />
    </label>

    <!-- Relaxation & Smoothing -->
    <label title="Number of Lloyd relaxation iterations. Each iteration moves seed points toward their cell centroids, creating more uniform cell shapes and sizes. Values of 2-5 typically produce good results. 0 disables relaxation.">
        Lloyd Iterations
        <input type="number" min="0" max="10" @bind="LloydIterations" disabled="@IsGenerating" />
    </label>

    <label title="Spacing between adjacent Voronoi cells. This gap is applied symmetrically, shrinking each cell by half the gap value. Creates visible separation between cells. Set to 0 for no gaps.">
        Cell Gap
        <input type="number" step="0.5" min="0" @bind="CellGap" disabled="@IsGenerating" />
    </label>

    <label title="Number of Chaikin corner-cutting smoothing iterations applied to each cell polygon. Higher values create smoother, more organic curves but reduce angular detail. 0 preserves sharp corners.">
        Smooth Iterations
        <input type="number" min="0" max="10" @bind="SmoothIterations" disabled="@IsGenerating" />
    </label>

    <label title="Uniform grow/shrink applied to each cell after gap calculation. Positive values expand cells outward, negative values shrink them inward. Applied after Cell Gap. Useful for fine-tuning final cell sizes.">
        Cell Offset
        <input type="number" step="0.5" @bind="CellOffset" disabled="@IsGenerating" />
    </label>

    <!-- Action Buttons -->
    <button @onclick="Generate" disabled="@(_import is null || IsGenerating)">
        @(IsGenerating ? "⏳ Generating…" : "▶️ Generate")
    </button>


    <button @onclick="ExportSvg" disabled="@(Result is null || IsGenerating)">
        📄 Export SVG
    </button>

    <button @onclick="ExportDxf" disabled="@(Result is null || IsGenerating)">
        📐 Export DXF
    </button>
</section>

<!-- Generation Status -->
@if (IsGenerating)
{
    <div class="gen-status">
        <div class="spinner" role="status" aria-label="Generating Voronoi diagram"></div>
        <span>Generating Voronoi diagram… This may take a moment for complex geometries.</span>
    </div>
}

<!-- Canvas Visualization -->
@if (_import?.Outer is not null)
{
    <section class="canvas-section">
        <VoronoiCanvas Boundary="_import!.Outer"
                       Holes="@(UseHoles ? _import!.Holes : null)"
                       ShowHoles="UseHoles"
                       Result="Result"
                       CanvasWidth="1200"
                       CanvasHeight="600" />
    </section>
}

@code {
    private DxfImport? _import;
    private Polygon? _effectiveBoundary;
    private List<Polygon>? _effectiveHoles;
    private List<Vector2> _seeds = new();

    // UI params
    private bool UseHoles { get; set; } = true;

    // Clamp in setters to enforce UI limits regardless of the HTML attributes.
    private double _outerOffset = 5;
    private double _innerOffset = 5;
    private double _cellGap = 5;
    private int _smoothIterations = 2;
    private double _cellOffset = 0;

    private double OuterOffset
    {
        get => _outerOffset;
        set => _outerOffset = Math.Max(0, value);
    }

    private double InnerOffset
    {
        get => _innerOffset;
        set => _innerOffset = Math.Max(0, value);
    }

    private double CellGap
    {
        get => _cellGap;
        set => _cellGap = Math.Max(0, value);
    }

    private int SmoothIterations
    {
        get => _smoothIterations;
        set => _smoothIterations = Math.Clamp(value, 0, 10);
    }

    private double CellOffset
    {
        get => _cellOffset;
        set => _cellOffset = value;
    }

    private int SeedCount { get; set; } = 200;
    private int RngSeed { get; set; } = 12345;
    private float PoissonRadius { get; set; } = 10f;
    private int LloydIterations { get; set; } = 0;

    public VoronoiResult? Result { get; set; }

    private bool IsGenerating { get; set; }
    private CancellationTokenSource? _genCts;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var bytes = ms.ToArray();

        try
        {
            _import = DxfLoader.Load(bytes, chordTolerance: 0.5, simplifyTolerance: 0.2);
            _effectiveBoundary = _import.Outer;
            _effectiveHoles = UseHoles ? _import.Holes : null;
            Result = null;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            _import = null;
            _effectiveBoundary = null;
            _effectiveHoles = null;
            Result = null;
            StateHasChanged();
        }
    }

    private async Task Generate()
    {
        if (_import is null || IsGenerating) return;

        IsGenerating = true;
        _genCts?.Dispose();
        _genCts = new CancellationTokenSource();
        var token = _genCts.Token;

        StateHasChanged();
        await Task.Yield();

        try
        {
            var boundary = _import.Outer;
            var rawHoles = UseHoles ? _import.Holes : new List<Polygon>();

            _effectiveBoundary = _outerOffset == 0 ? boundary : GeometryUtils.OffsetPolygon(boundary, -(_outerOffset));
            _effectiveHoles = UseHoles
                ? (_innerOffset == 0 ? rawHoles : rawHoles.Select(h => GeometryUtils.OffsetPolygon(h, _innerOffset)).ToList())
                : null;

            _seeds = SeedGenerator.GeneratePoisson(boundary, rawHoles, !UseHoles, PoissonRadius, RngSeed);
            if (_seeds.Count == 0 && SeedCount > 0)
            {
                _seeds = SeedGenerator.GenerateRandom(boundary, rawHoles, !UseHoles, SeedCount, RngSeed);
            }

            Result = await Task.Run(() =>
            {
                return LloydIterations > 0
                    ? VoronoiEngine.ComputeWithLloyd(boundary, rawHoles, !UseHoles, _seeds, LloydIterations, _outerOffset, _innerOffset, CellGap, SmoothIterations, CellOffset, token)
                    : VoronoiEngine.Compute(boundary, rawHoles, !UseHoles, _seeds, _outerOffset, _innerOffset, CellGap, SmoothIterations, CellOffset, token);
            }, token);
        }
        catch (OperationCanceledException)
        {
            // cancelled: keep previous Result
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            Result = null;
        }
        finally
        {
            IsGenerating = false;
            _genCts?.Dispose();
            _genCts = null;
            StateHasChanged();
        }
    }

    private void CancelGeneration()
    {
        _genCts?.Cancel();
    }

    private void ExportSvg()
    {
        if (Result is null || IsGenerating) return;
        var svg = SvgExporter.Export(Result, strokeWidth: 1f);
        var bytes = System.Text.Encoding.UTF8.GetBytes(svg);
        var base64 = Convert.ToBase64String(bytes);
        var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
        JS.InvokeVoidAsync("voronoiGen.downloadBlob", base64, "image/svg+xml", $"voronoi-{timestamp}.svg");
    }

    private void ExportDxf()
    {
        if (Result is null || IsGenerating) return;
        var bytes = DxfExporter.Export(Result);
        var base64 = Convert.ToBase64String(bytes);
        var timestamp = DateTime.Now.ToString("yyyyMMdd-HHmmss");
        JS.InvokeVoidAsync("voronoiGen.downloadBlob", base64, "application/dxf", $"voronoi-{timestamp}.dxf");
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
}