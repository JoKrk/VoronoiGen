@page "/"
@using SkiaSharp
@using VoronoiGen.Models
@using VoronoiGen.Services

<PageTitle>Voronoi DXF Tool</PageTitle>

<h1>Voronoi DXF — MVP</h1>

<!-- Inline workflow notes: upload DXF -> parse to boundary -> generate seeds -> compute voronoi -> preview -> export SVG -->
<InputFile OnChange="OnFileSelected" accept=".dxf" />

<div class="controls" style="margin-top:1rem;">
    <label>Seed Count
        <input type="number" min="1" max="2000" @bind="SeedCount" />
    </label>
    <label style="margin-left:1rem;">RNG Seed
        <input type="number" @bind="RngSeed" />
    </label>
    <button @onclick="Generate" disabled="@(_boundary is null)">Generate</button>
    <button @onclick="ExportSvg" disabled="@(Result is null)">Export SVG</button>
</div>

@if (_boundary is null)
{
    <p>Upload a DXF file with a closed outline to begin.</p>
}
else
{
    <p>Boundary loaded. Area: @_boundary.Area():F0. Click Generate to compute Voronoi.</p>
    <VoronoiCanvas Result="Result" />
}

@code {
    // State: boundary loaded from DXF, seeds, and current result
    private Polygon? _boundary;
    private List<SKPoint> _seeds = new();

    // UI params (MVP subset)
    private int SeedCount { get; set; } = 200;
    private int RngSeed { get; set; } = 12345;

    // Latest result bound into canvas and exporter
    public VoronoiResult? Result { get; set; }

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        // Parse DXF bytes fully client-side via DxfLoader
        var file = e.File;
        await using var stream = file.OpenReadStream(maxAllowedSize: 50 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        var bytes = ms.ToArray();

        try
        {
            var import = DxfLoader.Load(bytes, chordTolerance: 0.5, simplifyTolerance: 0.2);
            _boundary = import.Outer;
            Result = null; // reset view
        }
        catch (Exception ex)
        {
            Console.Error.WriteLine(ex);
            _boundary = null;
            Result = null;
        }
    }

    private Task Generate()
    {
        if (_boundary is null) return Task.CompletedTask;
        // Seeds via SeedGenerator, then Voronoi via VoronoiEngine
        _seeds = SeedGenerator.GenerateRandom(_boundary, SeedCount, RngSeed);
        Result = VoronoiEngine.Compute(_boundary, _seeds);
        StateHasChanged();
        return Task.CompletedTask;
    }

    private void ExportSvg()
    {
        if (Result is null) return;
        var svg = SvgExporter.Export(Result, strokeWidth: 1f);
        // Provide as a downloadable file via JS interop-free approach: data URL navigation
        var bytes = System.Text.Encoding.UTF8.GetBytes(svg);
        var base64 = Convert.ToBase64String(bytes);
        var url = $"data:image/svg+xml;base64,{base64}";
        JS.InvokeVoidAsync("open", url, "_blank");
    }

    [Inject] private IJSRuntime JS { get; set; } = default!;
}
