@page "/"
@using VoronoiGen.Models
@using VoronoiGen.Services
@using System.Numerics
@using System.Linq
@using System.Threading

<PageTitle>Voronoi DXF Tool</PageTitle>
<meta name="description" content="Generate Voronoi diagrams from DXF files for weight reduction, structural design, and generative art." />

<div class="app-layout">
    <aside class="sidebar">
        <header class="sidebar-header">
            <h1>Voronoi DXF</h1>
            <p class="text-muted text-small">Generate Voronoi diagrams from DXF files</p>
        </header>

        <section class="upload-section">
            <InputFile id="fileInput" OnChange="OnFileSelected" accept=".dxf" />
            @if (_import?.Outer is null)
            {
                <p class="upload-status">📁 Upload a DXF file to begin</p>
            }
            else
            {
                <div class="upload-status success">
                    <strong>✓ Boundary loaded</strong>
                    <div class="status-details">
                        <span>Area: <code>@Math.Round(_import!.Outer.Area(), 2)</code></span>
                        <span>Holes: <code>@_import!.Holes.Count</code></span>
                    </div>
                </div>
            }
        </section>

        <section class="controls">
            <h3 class="section-title">Parameters</h3>

            <div class="control-group">
                <h4 class="group-title">Boundary</h4>
                <label title="Enable / disable hole usage.">
                    Use Holes
                    <input type="checkbox" @bind="UseHoles" disabled="@IsGenerating" />
                </label>
                <label title="Inset margin from outer boundary (shrinks free area).">
                    Outer Offset
                    <input type="number" step="0.5" min="0" @bind="OuterOffset" disabled="@IsGenerating" />
                </label>
                <label title="Grow hole outlines outward (reduces free area).">
                    Inner Offset
                    <input type="number" step="0.5" min="0" @bind="InnerOffset" disabled="@IsGenerating" />
                </label>
            </div>

            <div class="control-group">
                <h4 class="group-title">Seed Generation</h4>
                <label title="Poisson disk radius (larger = fewer seeds).">
                    Min Spacing (Poisson)
                    <input type="number" step="0.5" min="1" @bind="PoissonRadius" disabled="@IsGenerating" />
                </label>
                <label title="Fallback random seed count if Poisson fails.">
                    Seed Count
                    <input type="number" min="1" max="5000" @bind="SeedCount" disabled="@IsGenerating" />
                </label>
                <label title="Deterministic RNG seed.">
                    RNG Seed
                    <input type="number" @bind="RngSeed" disabled="@IsGenerating" />
                </label>
                <label title="Lloyd relaxation iterations (0 = none).">
                    Lloyd Iterations
                    <input type="number" min="0" max="10" @bind="LloydIterations" disabled="@IsGenerating" />
                </label>
            </div>

            <div class="control-group">
                <h4 class="group-title">Cell Processing</h4>
                <label title="Gap between cells (shrinks each cell).">
                    Cell Gap
                    <input type="number" step="0.5" min="0" @bind="CellGap" disabled="@IsGenerating" />
                </label>
                <label title="Smoothing iterations (affects automatic radius estimation when Corner Radius = 0).">
                    Smooth Iterations
                    <input type="number" min="0" max="10" @bind="SmoothIterations" disabled="@IsGenerating" />
                </label>
                <label title="Filter out cells below this area (0 disables).">
                    Min Cell Area
                    <input type="number" step="1" min="0" @bind="MinCellArea" disabled="@IsGenerating" />
                </label>
                <label title="Max width/height (or height/width) ratio (0 disables).">
                    Max Aspect Ratio
                    <input type="number" step="0.5" min="0" @bind="MaxAspectRatio" disabled="@IsGenerating" />
                </label>

                <div class="sub-group">
                    <h5 class="sub-title">Rounding / Smoothing</h5>
                    <label title="Explicit corner fillet radius in drawing units (0 = auto based on Smooth Iterations & gap).">
                        Corner Radius
                        <input type="number" step="0.5" min="0" @bind="RoundRadius" disabled="@IsGenerating" />
                    </label>
                    <label title="Chaikin weight (0.01–0.49). Higher = more round. Applied lightly after radius rounding.">
                        Chaikin Weight
                        <input type="number" step="0.01" min="0.01" max="0.49" @bind="ChaikinWeight" disabled="@IsGenerating" />
                    </label>
                    <label title="Arc tessellation tolerance for rounded corners (0 = auto). Lower = smoother (more points).">
                        Arc Tolerance
                        <input type="number" step="0.25" min="0" @bind="RoundArcTolerance" disabled="@IsGenerating" />
                    </label>
                </div>
            </div>

            <div class="control-group">
                <h4 class="group-title">Export Geometry</h4>
                <label title="Choose whether DXF export uses original polygon edges or spline-fitted curves.">
                    Mode
                    <select @bind="ExportMode" disabled="@IsGenerating">
                        <option value="Polylines">Polylines</option>
                        <option value="Splines">Splines</option>
                    </select>
                </label>

                @if (ExportMode == ExportGeometryMode.Splines)
                {
                    <label title="Catmull–Rom tension (0 = loose, 1 = tight).">
                        Spline Tension
                        <input type="number" min="0" max="1" step="0.05" @bind="SplineTension" disabled="@IsGenerating" />
                    </label>
                    <label title="Fit-point samples per cubic segment for DXF SPLINE (higher = smoother).">
                        Samples / Segment
                        <input type="number" min="2" max="32" step="1" @bind="SplineSamplesPerBezier" disabled="@IsGenerating" />
                    </label>
                }
            </div>
        </section>

        <section class="actions">
            <button class="btn-primary" @onclick="Generate" disabled="@(_import is null || IsGenerating)">
                @(IsGenerating ? "⏳ Generating…" : "▶️ Generate")
            </button>
            <button class="btn-success" @onclick="ExportDxf" disabled="@(Result is null || IsGenerating)">
                @(ExportMode == ExportGeometryMode.Splines ? "🎛 Export Splines" : "📐 Export Polylines")
            </button>
        </section>

        @if (IsGenerating)
        {
            <div class="gen-status">
                <div class="spinner"></div>
                <span>Generating…</span>
            </div>
        }
    </aside>

    <main class="canvas-area">
        @if (_import?.Outer is null)
        {
            <div class="canvas-placeholder">
                <div class="placeholder-content">
                    <h2>Upload a DXF File</h2>
                    <p>Select a closed outline DXF to begin.</p>
                </div>
            </div>
        }
        else
        {
            <div class="canvas-container">
                <VoronoiCanvas Boundary="_import!.Outer"
                               Holes="@(UseHoles ? _import!.Holes : null)"
                               ShowHoles="UseHoles"
                               Result="Result"
                               UseSplineDisplay="@(ExportMode == ExportGeometryMode.Splines)"
                               SplineTension="SplineTension"
                               SplineSamplesPerBezier="SplineSamplesPerBezier" />
            </div>
        }
    </main>
</div>

@code {
    private DxfImport? _import;
    private List<Vector2> _seeds = new();

    // Boundary options
    private bool UseHoles { get; set; } = true;
    private double _outerOffset = 8;
    private double _innerOffset = 5;
    private double _cellGap = 3;
    private int _smoothIterations = 2;
    private double _minCellArea = 0;
    private double _maxAspectRatio = 0;

    private double OuterOffset { get => _outerOffset; set => _outerOffset = Math.Max(0, value); }
    private double InnerOffset { get => _innerOffset; set => _innerOffset = Math.Max(0, value); }
    private double CellGap { get => _cellGap; set => _cellGap = Math.Max(0, value); }
    private int SmoothIterations { get => _smoothIterations; set => _smoothIterations = Math.Clamp(value, 0, 10); }
    private double MinCellArea { get => _minCellArea; set => _minCellArea = Math.Max(0, value); }
    private double MaxAspectRatio { get => _maxAspectRatio; set => _maxAspectRatio = Math.Max(0, value); }

    // Rounding parameters
    private double _roundRadius = 0;
    private float _chaikinWeight = 0.25f;
    private double _roundArcTolerance = 0;

    private double RoundRadius { get => _roundRadius; set => _roundRadius = Math.Max(0, value); }
    private float ChaikinWeight { get => _chaikinWeight; set => _chaikinWeight = Math.Clamp(value, 0.01f, 0.49f); }
    private double RoundArcTolerance { get => _roundArcTolerance; set => _roundArcTolerance = Math.Max(0, value); }

    // Seed params
    private int SeedCount { get; set; } = 200;
    private int RngSeed { get; set; } = 12345;
    private float PoissonRadius { get; set; } = 10f;
    private int LloydIterations { get; set; } = 3;

    // Export mode
    private enum ExportGeometryMode { Polylines, Splines }
    private ExportGeometryMode ExportMode { get; set; } = ExportGeometryMode.Polylines;
    private double SplineTension { get; set; } = 0.25;
    private int SplineSamplesPerBezier { get; set; } = 4;

    public VoronoiResult? Result { get; set; }
    private bool IsGenerating { get; set; }
    private CancellationTokenSource? _genCts;

    private async Task OnFileSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        await using var stream = file.OpenReadStream(50 * 1024 * 1024);
        using var ms = new MemoryStream();
        await stream.CopyToAsync(ms);
        try
        {
            _import = DxfLoader.Load(ms.ToArray(), chordTolerance: 0, simplifyTolerance: 0.2);
            Result = null;
            StateHasChanged();
        }
        catch
        {
            _import = null;
            Result = null;
            StateHasChanged();
        }
    }

    private async Task Generate()
    {
        if (_import is null || IsGenerating) return;
        IsGenerating = true;
        _genCts?.Dispose();
        _genCts = new CancellationTokenSource();
        var token = _genCts.Token;
        StateHasChanged();
        await Task.Yield();

        try
        {
            var boundary = _import.Outer;
            var holes = UseHoles ? _import.Holes : new List<Polygon>();

            _seeds = SeedGenerator.GeneratePoisson(boundary, holes, !UseHoles, PoissonRadius, RngSeed);
            if (_seeds.Count == 0 && SeedCount > 0)
                _seeds = SeedGenerator.GenerateRandom(boundary, holes, !UseHoles, SeedCount, RngSeed);

            Result = await Task.Run(() =>
                LloydIterations > 0
                    ? VoronoiEngine.ComputeWithLloyd(boundary, holes, !UseHoles, _seeds, LloydIterations,
                        OuterOffset, InnerOffset, CellGap, SmoothIterations, MinCellArea, MaxAspectRatio,
                        RoundRadius, ChaikinWeight, RoundArcTolerance, token)
                    : VoronoiEngine.Compute(boundary, holes, !UseHoles, _seeds,
                        OuterOffset, InnerOffset, CellGap, SmoothIterations, MinCellArea, MaxAspectRatio,
                        RoundRadius, ChaikinWeight, RoundArcTolerance, token),
                token);
        }
        catch (OperationCanceledException) { }
        catch
        {
            Result = null;
        }
        finally
        {
            IsGenerating = false;
            _genCts?.Dispose();
            _genCts = null;
            StateHasChanged();
        }
    }

    private void ExportDxf()
    {
        if (Result is null || IsGenerating) return;
        var holes = UseHoles ? _import?.Holes : null;

        byte[] bytes = ExportMode == ExportGeometryMode.Splines
            ? DxfExporter.ExportSplines(Result, holes, (float)SplineTension, SplineSamplesPerBezier)
            : DxfExporter.ExportPolylines(Result, holes);

        var base64 = Convert.ToBase64String(bytes);
        var ts = DateTime.Now.ToString("yyyyMMdd-HHmmss");
        var suffix = ExportMode == ExportGeometryMode.Splines ? "splines" : "polylines";
        JS.InvokeVoidAsync("voronoiGen.downloadBlob", base64, "application/dxf", $"voronoi-{suffix}-{ts}.dxf");
    }

    private void CancelGeneration() => _genCts?.Cancel();

    [Inject] private IJSRuntime JS { get; set; } = default!;
}