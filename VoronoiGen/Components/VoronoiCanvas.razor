@using System.Numerics
@using VoronoiGen.Models
@using VoronoiGen.Services
@inject Microsoft.JSInterop.IJSRuntime JS
@implements IAsyncDisposable

@if (Boundary is null && Result is null)
{
    <p><!-- idle --></p>
}
else
{
    <div @ref="_containerRef" style="width:100%;height:100%;">
        <canvas @ref="_canvasRef"
                style="border:1px solid #ddd;display:block;width:100%;height:100%;"></canvas>
    </div>

    @if (ShowDebug)
    {
        <div class="debug" style="font-family:monospace;font-size:12px;margin-top:4px;color:#333;">
            <div>Cells: @(_cellCount) | Seeds: @(_seedCount) | BoundaryPts: @_boundaryPts | Holes: @_holeCount</div>
            <div>Bounds: L=@_lastBounds.Left:F2 T=@_lastBounds.Top:F2 W=@_lastBounds.Width:F2 H=@_lastBounds.Height:F2</div>
            <div>Canvas: W=@_lastCanvasW H=@_lastCanvasH | Scale=@_lastScale:F6 | Mode=@(UseSplineDisplay ? "Spline" : "Polyline")</div>
        </div>
    }
}

@code {
    [Parameter] public Polygon? Boundary { get; set; }
    [Parameter] public VoronoiResult? Result { get; set; }
    [Parameter] public List<Polygon>? Holes { get; set; }
    [Parameter] public bool ShowHoles { get; set; } = true;
    [Parameter] public bool ShowDebug { get; set; } = false;

    // Display parameters
    [Parameter] public bool UseSplineDisplay { get; set; } = false;
    [Parameter] public double SplineTension { get; set; } = 0.5;
    [Parameter] public int SplineSamplesPerBezier { get; set; } = 0; // reserved

    private ElementReference _containerRef;
    private ElementReference _canvasRef;
    private IJSObjectReference? _module;
    private bool _moduleReady;
    private bool _invalidateAfterRender;

    private int _cellCount, _seedCount, _boundaryPts, _holeCount;
    private RectD _lastBounds;
    private int _lastCanvasW, _lastCanvasH;
    private float _lastScale;

    protected override void OnParametersSet()
    {
        if (Boundary is not null || Result is not null)
        {
            if (_moduleReady)
                _ = RenderAsync();
            else
                _invalidateAfterRender = true;
        }
        base.OnParametersSet();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _module = await JS.InvokeAsync<IJSObjectReference>("import", "/js/voronoiCanvas.js");
            _moduleReady = true;
        }

        if (_invalidateAfterRender && _moduleReady)
        {
            _invalidateAfterRender = false;
            await RenderAsync();
        }

        await base.OnAfterRenderAsync(firstRender);
    }

    public async ValueTask DisposeAsync()
    {
        if (_module is not null)
        {
            try { await _module.DisposeAsync(); } catch { }
        }
    }

    private async Task RenderAsync()
    {
        if (!_moduleReady || _module is null) return;

        try
        {
            var containerSize = await _module.InvokeAsync<ContainerSize>("getContainerSize", _containerRef);
            if (containerSize.Width <= 0 || containerSize.Height <= 0) return;

            var workBoundary = Result?.Boundary ?? Boundary;
            var originalBoundary = Boundary;

            if (workBoundary is null || workBoundary.Points.Count < 3)
            {
                var prepOnly = await _module.InvokeAsync<PrepareResult>("prepareCanvas", _canvasRef, containerSize.Width, containerSize.Height);
                _lastCanvasW = prepOnly.pixelWidth;
                _lastCanvasH = prepOnly.pixelHeight;
                await _module.InvokeVoidAsync("clearCanvas", _canvasRef, _lastCanvasW, _lastCanvasH);
                return;
            }

            var prep = await _module.InvokeAsync<PrepareResult>("prepareCanvas", _canvasRef, containerSize.Width, containerSize.Height);
            var pixelW = prep.pixelWidth;
            var pixelH = prep.pixelHeight;
            _lastCanvasW = pixelW;
            _lastCanvasH = pixelH;

            var bounds = ComputeBounds(workBoundary.Points);
            if (Result is not null && originalBoundary is not null && originalBoundary.Points.Count >= 3)
                bounds = UnionBounds(bounds, ComputeBounds(originalBoundary.Points));
            _lastBounds = bounds;

            if (bounds.Width <= 0 || bounds.Height <= 0)
            {
                await _module.InvokeVoidAsync("clearCanvas", _canvasRef, pixelW, pixelH);
                return;
            }

            const double marginPercent = 0.04;
            var margin = Math.Max(10, Math.Min(pixelW, pixelH) * marginPercent);
            var effectiveW = pixelW - 2 * margin;
            var effectiveH = pixelH - 2 * margin;
            if (effectiveW <= 0 || effectiveH <= 0)
            {
                await _module.InvokeVoidAsync("clearCanvas", _canvasRef, pixelW, pixelH);
                return;
            }

            var scaleX = effectiveW / bounds.Width;
            var scaleY = effectiveH / bounds.Height;
            var scale = (float)Math.Min(scaleX, scaleY);
            _lastScale = scale;
            var contentW = bounds.Width * scale;
            var contentH = bounds.Height * scale;
            var offsetX = margin + (effectiveW - contentW) * 0.5;
            var offsetY = margin + (effectiveH - contentH) * 0.5;

            _cellCount = Result?.Cells?.Count ?? 0;
            _seedCount = Result?.Seeds?.Count ?? 0;
            _boundaryPts = workBoundary.Points.Count;
            _holeCount = Holes?.Count ?? 0;

            var boundaryFlat = ToFlatArray(workBoundary.Points);
            double[]? originalBoundaryFlat = (Result is not null && originalBoundary?.Points.Count >= 3)
                ? ToFlatArray(originalBoundary.Points)
                : null;

            // Cells: polyline or Bézier
            double[][] cellsPoly = Array.Empty<double[]>();
            double[][] cellsBezier = Array.Empty<double[]>();

            if (Result?.Cells is { Count: > 0 } cells)
            {
                if (!UseSplineDisplay)
                {
                    cellsPoly = cells.Where(c => c.Points.Count >= 3)
                                     .Select(c => ToFlatArray(c.Points))
                                     .ToArray();
                }
                else
                {
                    cellsBezier = cells.Where(c => c.Points.Count >= 3)
                        .Select(c => ToBezierFlat(c.Points, (float)SplineTension))
                        .Where(a => a.Length >= 8)
                        .ToArray();
                }
            }

            // Holes: always polylines
            double[][] holesPoly = Array.Empty<double[]>();
            if (ShowHoles && Holes is { Count: > 0 })
            {
                holesPoly = Holes.Where(h => h.Points.Count >= 3)
                                 .Select(h => ToFlatArray(h.Points))
                                 .ToArray();
            }

            var seedsFlat = Result?.Seeds is { Count: > 0 } seeds
                ? ToFlatArray(seeds)
                : Array.Empty<double>();

            var hud = ShowDebug
                ? new[]
                {
                    $"cells:{_cellCount}",
                    $"scale:{scale:F6}",
                    $"mode:{(UseSplineDisplay?"spline":"poly")}",
                    $"bounds:{bounds.Left:F1},{bounds.Top:F1} {bounds.Width:F1}x{bounds.Height:F1}"
                }
                : Array.Empty<string>();

            var payload = new
            {
                pixelWidth = pixelW,
                pixelHeight = pixelH,
                boundsLeft = bounds.Left,
                boundsTop = bounds.Top,
                offsetX,
                offsetY,
                scale,
                boundary = boundaryFlat,
                originalBoundary = originalBoundaryFlat,
                cells = cellsPoly,
                cellsBezier,
                holes = holesPoly,          // only polylines
                splineMode = UseSplineDisplay,
                seeds = seedsFlat,
                showHoles = ShowHoles,
                showDebug = ShowDebug,
                hudLines = hud
            };

            await _module.InvokeVoidAsync("drawVoronoi", _canvasRef, payload);
        }
        catch (Exception ex)
        {
            Console.WriteLine("[VoronoiCanvas] RenderAsync exception: " + ex);
        }
    }

    private static double[] ToFlatArray(IReadOnlyList<Vector2> points)
    {
        var arr = new double[points.Count * 2];
        for (int i = 0, j = 0; i < points.Count; i++, j += 2)
        {
            arr[j] = points[i].X;
            arr[j + 1] = points[i].Y;
        }
        return arr;
    }

    // Flatten Bézier segments: start (P0) then groups (C1, C2, P3)
    private static double[] ToBezierFlat(IReadOnlyList<Vector2> points, float tension)
    {
        var segments = SplineUtils.ToClosedCubicBeziers(points, tension);
        if (segments.Count == 0) return Array.Empty<double>();

        var arr = new double[2 + segments.Count * 6];
        arr[0] = segments[0].P0.X;
        arr[1] = segments[0].P0.Y;
        int k = 2;
        foreach (var s in segments)
        {
            arr[k++] = s.C1.X; arr[k++] = s.C1.Y;
            arr[k++] = s.C2.X; arr[k++] = s.C2.Y;
            arr[k++] = s.P3.X; arr[k++] = s.P3.Y;
        }
        return arr;
    }

    private static RectD ComputeBounds(IReadOnlyList<Vector2> pts)
    {
        if (pts.Count == 0) return default;
        double minX = pts[0].X, maxX = pts[0].X, minY = pts[0].Y, maxY = pts[0].Y;
        for (int i = 1; i < pts.Count; i++)
        {
            var p = pts[i];
            if (p.X < minX) minX = p.X;
            if (p.X > maxX) maxX = p.X;
            if (p.Y < minY) minY = p.Y;
            if (p.Y > maxY) maxY = p.Y;
        }
        return new RectD(minX, minY, Math.Max(0, maxX - minX), Math.Max(0, maxY - minY));
    }

    private static RectD UnionBounds(RectD a, RectD b)
    {
        double left = Math.Min(a.Left, b.Left);
        double top = Math.Min(a.Top, b.Top);
        double right = Math.Max(a.Left + a.Width, b.Left + b.Width);
        double bottom = Math.Max(a.Top + a.Height, b.Top + b.Height);
        return new RectD(left, top, right - left, bottom - top);
    }

    private record struct RectD(double Left, double Top, double Width, double Height);
    private record PrepareResult(int pixelWidth, int pixelHeight, double dpr);
    private record ContainerSize(int Width, int Height);
}