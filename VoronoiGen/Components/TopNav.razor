<nav class="top-nav" role="navigation" aria-label="Main">

    <button class="nav-toggle" @onclick="ToggleNav" aria-label="Toggle navigation" aria-expanded="@isExpanded">
        <span class="hamburger"></span>
    </button>

    <div class="nav-links @(isExpanded ? "open" : "")">
        <a href="/" @onclick="CloseNav">Tool</a>
        <a href="/story" @onclick="CloseNav">Story</a>
        <a href="/privacy" @onclick="CloseNav">Privacy</a>
    </div>
</nav>

@code {
    private bool isExpanded;

    private void ToggleNav() => isExpanded = !isExpanded;
    private void CloseNav() => isExpanded = false;
}